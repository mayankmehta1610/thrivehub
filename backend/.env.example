# Copy to .env for local development. On Render, set these in the dashboard.
DATABASE_URL=sqlite:///./thrivehub.db
DATABASE_SCHEMA=thrivehub
SECRET_KEY=thrivehub-dev-secret-change-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional
# REDIS_URL=redis://localhost:6379
# S3_ENDPOINT=
# S3_BUCKET=thrivehub-media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# FCM_SERVER_KEY=
# FCM_PROJECT_ID=
